<script>
    $(document).ready(function () {
        $("#ActivedDate").datepicker({
            format: "yyyy/mm/dd",
            minViewMode: 0,
            autoclose: true
        });
        $("#DeActivedDate").datepicker({
            format: "yyyy/mm/dd",
            minViewMode: 0,
            autoclose: true
        });
    });

    $("#ActivedDate").keydown(function () {
        return false;
    });
    $("#DeActivedDate").keydown(function () {
        return false;
    });
</script>