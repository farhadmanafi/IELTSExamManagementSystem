@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
}

<div class="login login-3 wizard d-flex flex-column flex-lg-row flex-column-fluid">
    <!--begin::Aside-->
    <div class="login-aside d-flex flex-column flex-row-auto">
        <!--begin::Aside Top-->
        <div class="d-flex flex-column-auto flex-column pt-lg-40 pt-15">
            <!--begin::Aside header-->
            <a href="#" class="login-logo text-center pt-lg-25 pb-10">
                @*<img src="~/assets/media/logos/logo-1.png" class="max-h-70px" alt="" />*@
                <img src="/image/Logo.png" class="max-h-70px" />
            </a>
            <!--end::Aside header-->
            <!--begin::Aside Title-->
            <h3 class="font-weight-bolder text-center font-size-h4 text-dark-50 line-height-xl">
                IELTS Online Exam Institute
            </h3>
            <!--end::Aside Title-->
        </div>
        <!--end::Aside Top-->
        <!--begin::Aside Bottom-->
        <div class="aside-img d-flex flex-row-fluid bgi-no-repeat bgi-position-x-center"
                          style="background-position-y: calc(70% + 5rem);
                background-image: url(/image/Logo-Background.png)"></div>
        <!--end::Aside Bottom-->
    </div>
    <!--begin::Aside-->
    <!--begin::Content-->
    <div class="login-content flex-row-fluid d-flex flex-column p-10">
        <!--begin::Top-->
        @*<div class="text-right d-flex justify-content-center">
                <div class="top-signin text-right d-flex justify-content-end pt-5 pb-lg-0 pb-10">
                    <span class="font-weight-bold text-muted font-size-h4">Having issues?</span>
                    <a href="javascript:;" class="font-weight-bold text-primary font-size-h4 ml-2" id="kt_login_signup">Get Help</a>
                </div>
            </div>*@
        <!--end::Top-->
        <!--begin::Wrapper-->
        <div class="d-flex flex-row-fluid flex-center">
            <!--begin::Signin-->
            <div class="login-form">
                <!--begin::Form-->
                <form method="post">
                    <input asp-for="Input.Code" type="hidden" />
                    <h4>@ViewData["Title"]</h4>
                    <hr />
                    <div asp-validation-summary="All" class="text-danger"></div>
                    <div class="form-group">
                        <label class="font-size-h6 font-weight-bolder text-dark">Email</label>
                        <input asp-for="Input.Email" class="form-control h-auto py-7 px-6 rounded-lg border-0" autocomplete="off" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label class="font-size-h6 font-weight-bolder text-dark">Password</label>
                        <input asp-for="Input.Password" class="form-control h-auto py-7 px-6 rounded-lg border-0" autocomplete="off" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label class="font-size-h6 font-weight-bolder text-dark">ConfirmPassword</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control h-auto py-7 px-6 rounded-lg border-0" autocomplete="off" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <button type="submit" class="btn btn-primary font-weight-bolder font-size-h6 px-8 py-4 my-3 mr-3">Reset</button>
                    </div>
                </form>
                <!--end::Form-->
            </div>
            <!--end::Signin-->
        </div>
        <!--end::Wrapper-->
    </div>
    <!--end::Content-->
</div>
