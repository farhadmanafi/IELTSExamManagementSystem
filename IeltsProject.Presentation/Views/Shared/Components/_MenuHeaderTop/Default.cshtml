@model IEnumerable<ExamContext.ReadModel.Queries.Contracts.GeneralContext.UserPanelMenuAggregate.DataContracts.UserPanelMenuQueryFacadeDto>
<ul class="header-tabs nav align-self-end font-size-lg" role="tablist">
	@if (Model.Count() > 0)
	{
		var activeMenu = true;
		int i = 1;
		foreach (var item in Model)
		{
			if (activeMenu == true)
				{
					<li class="nav-item">
						<a href="#" class="nav-link py-4 px-6 active" data-toggle="tab" data-target="#tab_@i" role="tab">@item.Title</a>
					</li>
				}
				else
				{
					<li class="nav-item mr-3">
						<a href="#" class="nav-link py-4 px-6" data-toggle="tab" data-target="#tab_@i" role="tab">@item.Title</a>
					</li>
				}
			<!--begin::Item-->
			activeMenu = false;
			++i;
		}
	}
</ul>
