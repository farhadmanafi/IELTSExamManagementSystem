@using Ielts.Common.GeneralClass
@model IeltsProject.Presentation.Models.IeltsSpeakingQuestionAnswereViewModel

<div class="card card-custom gutter-b">
    <div class="card-header">
        <div class="card-title">
            <span class="card-icon">
                <i class="flaticon2-chart text-primary"></i>
            </span>
            <h3 class="card-label">Speaking Exam</h3>
        </div>
    </div>
    <div class="card-body">
        <div class="row justify-content-center">
            <!--begin: Pricing-->
            @if (ViewBag.HasError == true)
            {
                <div class="col" style="text-align:center">
                    <div class="alert alert-custom alert-outline-danger fade show mb-5" role="alert">
                        <div class="alert-icon"><i class="flaticon-danger"></i></div>
                        <div class="alert-text">@Html.ValidationMessage("IeltsExamSpeakingPageException")</div>
                        <div class="alert-close">
                            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                <span aria-hidden="true"><i class="ki ki-close"></i></span>
                            </button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                @using (Html.BeginForm("IeltsExamSpeakingPage", "IeltsExamSpeaking", FormMethod.Post, new { @class = "col-md-10 form" }))
                {
                    <input type="hidden" name="IeltsExamId" value="@Model.IeltsExamId" />
                    <input type="hidden" name="IeltsSpeakingId" value="@Model.IeltsSpeakingId" />
                    <input type="hidden" name="IeltsExamParticipantId" value="@Model.IeltsExamParticipantId" />
                    <div class="card-body">
                        <div class="example example-basic">
                            <div class="example-preview bgi-no-repeat gutter-b card-stretch"
                                 style="background-position: right top; background-size: 30% auto; background-image: url(/assets/media/svg/shapes/abstract-3.svg)">
                                <div class="form-group">
                                    <label class="">Select Time</label>
                                    @Html.DropDownListFor(m => m.MeetingId, ViewBag.SpeakingExamSectionList as SelectList, "..Selecting..", new { @class = "form-control form-control-solid form-control-lg" })
                                </div>
                                <div class="separator separator-dashed my-10"></div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer">
                        <div class="row">
                            <div class="col-lg-5"></div>
                            <div class="col-lg-7">
                                <button type="submit" class="btn btn-primary mr-2">Submit</button>
                                <a href="/" class="btn btn-secondary">Cancel</a>
                            </div>
                        </div>
                    </div>
                }

            }
            <!--end: Pricing-->
        </div>
    </div>
</div>



<style>
    .notshow {
        display: none;
    }
</style>




