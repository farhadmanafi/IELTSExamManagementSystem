@model IList<ExamContext.ReadModel.Queries.Contracts.OnlinePlacementContext.PlacementExamAggregate.DataContracts.PlacementExamQueryFacadeDto>

<div class="row">
    @foreach(var item in Model)
    {
         <div class="col-xl-6">
        <!--begin::Engage Widget 11-->
        <div class="card card-custom card-stretch gutter-b">
            <div class="card-body d-flex p-0">
                <div class="flex-grow-1 p-20 pb-40 card-rounded flex-grow-1 bgi-no-repeat" style="background-position: calc(100% + 0.5rem) bottom;
                    background-size: 50% auto; background-image: url(../assets/media/svg/humans/custom-10.svg)">
                    <h2 class="text-dark pb-5 font-weight-bolder">@item.Title</h2>
                    <p class="text-dark-50 pb-5 font-size-h5">
                        @item.Description
                    </p>
                    <a href="/OnlinePlacement/OnlinePlacementRegisterPage/@item.Id" class="btn btn-danger font-weight-bold py-2 px-6">Take The Test</a>
                </div>
            </div>
        </div>
        <!--end::Engage Widget 11-->
    </div>
    }   
</div>